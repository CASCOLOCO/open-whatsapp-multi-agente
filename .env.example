# ====================================
# Open WhatsApp Multi Agente - Configuracion
# ====================================
# Copia este archivo como .env y completa los valores

# === Configuracion General ===
NEXT_PUBLIC_APP_NAME=WhatsApp CRM
NEXT_PUBLIC_BASE_URL=https://tu-dominio.com
PORT=3001
NODE_ENV=production

# === Base de datos PostgreSQL ===
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/whatsapp_crm

# === WhatsApp Cloud API (Meta) ===
# Obtener en: https://developers.facebook.com → Tu App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=tu_token_permanente_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_WABA_ID=tu_whatsapp_business_account_id
WHATSAPP_VERIFY_TOKEN=un_token_secreto_cualquiera

# === Seguridad ===
IMPORT_SECRET=cambia_esto_por_un_secreto_seguro
